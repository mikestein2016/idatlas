---
---
<section id="contact" class="bg-slate-900 text-white">
  <div class="mx-auto max-w-3xl px-6 py-20">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">Let's talk about your training problem</h2>
    <p class="text-lg text-slate-300 mb-10 leading-relaxed text-center">
      We start every engagement with a free 30-minute discovery call. We use it to understand what you're actually trying to accomplish before we propose anything. No commitment, no pitch deck, no follow-up if it isn't the right fit.
    </p>

    <form id="contact-form" class="bg-slate-800 rounded-2xl p-6 md:p-8 space-y-5" onsubmit="event.preventDefault(); const f=event.target; const subject=encodeURIComponent('ID Atlas inquiry from '+f.elements.name.value); const body=encodeURIComponent('Name: '+f.elements.name.value+'\nEmail: '+f.elements.email.value+'\nOrganization: '+(f.elements.organization.value||'(not provided)')+'\n\n'+f.elements.message.value); window.location.href='mailto:mike@idatlas.org?subject='+subject+'&body='+body;">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <label class="block">
          <span class="text-sm font-medium text-slate-200">Your name</span>
          <input name="name" type="text" required class="mt-2 w-full rounded-lg bg-slate-900 border border-slate-700 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-400" placeholder="First and last" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-200">Your email</span>
          <input name="email" type="email" required class="mt-2 w-full rounded-lg bg-slate-900 border border-slate-700 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-400" placeholder="you@example.org" />
        </label>
      </div>
      <label class="block">
        <span class="text-sm font-medium text-slate-200">Organization <span class="text-slate-500 font-normal">(optional)</span></span>
        <input name="organization" type="text" class="mt-2 w-full rounded-lg bg-slate-900 border border-slate-700 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-400" placeholder="Where you work" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-200">What can we help with?</span>
        <textarea name="message" rows="5" required class="mt-2 w-full rounded-lg bg-slate-900 border border-slate-700 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-400 resize-y" placeholder="A sentence or two about what you're working on, and we'll take it from there."></textarea>
      </label>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-2">
        <p class="text-xs text-slate-400">Sends via your email client. We reply within two business days.</p>
        <button type="submit" class="inline-flex items-center justify-center gap-2 bg-white text-slate-900 rounded-full px-6 py-3 text-sm font-semibold hover:bg-slate-100 transition">
          Send inquiry
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </form>
  </div>
</section>
