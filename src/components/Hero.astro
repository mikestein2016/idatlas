---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-12 md:py-16">
    <div class="bg-slate-900 text-white rounded-3xl overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center p-8 md:p-12 lg:p-16">
        <div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight">
            Training built for <span class="text-amber-400 whitespace-nowrap">mission-driven</span> work.
          </h1>
          <p class="mt-6 text-lg md:text-xl text-slate-300 leading-relaxed">
            Custom e-learning, microlearning, and serious games for nonprofits, universities, and mission-led startups. We map what your team actually needs to learn, then design and build it within your budget.
          </p>
          <p class="mt-4 text-sm text-slate-400">
            Trusted by ISRG, Johns Hopkins, UMD, HIAS, Texas State, and more.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#contact" class="inline-flex items-center gap-2 bg-white text-slate-900 rounded-full px-6 py-3 text-sm font-semibold hover:bg-slate-100 transition">
              Book a discovery call
              <span aria-hidden="true">→</span>
            </a>
            <a href="#recent-work" class="inline-flex items-center gap-2 border border-slate-600 text-slate-200 rounded-full px-6 py-3 text-sm font-semibold hover:bg-slate-800 transition">
              See our work
            </a>
          </div>
        </div>
        <div class="relative">
          <img src={`${base}/images/hero.jpg`} alt="Hand-drawn learning map with annotated nodes and connections on paper" class="rounded-2xl w-full h-auto shadow-2xl" />
        </div>
      </div>
    </div>
  </div>
</section>
