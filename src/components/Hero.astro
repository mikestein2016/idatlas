---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="bg-white relative overflow-hidden">
  <img src={`${base}/images/lined-bg.webp`} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover opacity-25 pointer-events-none" />
  <div class="relative mx-auto max-w-7xl px-6 py-12 md:py-16">
    <div class="bg-slate-900 text-white rounded-3xl overflow-hidden shadow-xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-stretch p-8 md:p-12 lg:p-16">
        <div class="lg:col-span-8 flex flex-col justify-center">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight">
            Training built for <span class="whitespace-nowrap"><span class="text-amber-400">mission-driven</span> work.</span>
          </h1>
          <p class="mt-6 text-lg md:text-xl text-slate-300 leading-relaxed">
            Custom e-learning, microlearning, and serious games for nonprofits, universities, and mission-led startups. We map what your team actually needs to learn, then design and build it within your budget.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#contact" class="inline-flex items-center gap-2 bg-white text-slate-900 rounded-full px-6 py-3 text-sm font-semibold hover:bg-slate-100 transition">
              Book a discovery call
              <span aria-hidden="true">→</span>
            </a>
            <a href="#recent-work" class="inline-flex items-center gap-2 border border-slate-600 text-slate-200 rounded-full px-6 py-3 text-sm font-semibold hover:bg-slate-800 transition">
              See our work
            </a>
          </div>
        </div>
        <div class="lg:col-span-4 relative">
          <img src={`${base}/images/learning-map-hero.webp`} alt="Hand-drawn learning design map showing a structured framework for course development" class="rounded-2xl w-full h-full object-cover shadow-2xl" />
        </div>
      </div>
    </div>
  </div>
</section>
